#!/bin/bash

if [ "${EUID:-$(id -u)}" -ne 0 ]; then
  echo "ERROR: ejecuta este instalador como root (sudo bash one_corregido)." >&2
  exit 1
fi

cat > /root/jelly_manager.sh <<'BASH'
#!/bin/bash

set -o pipefail

# ============================================================
# JELLYFIN MANAGER - BAREMETAL + RCLONE + BACKUP LOCAL
# Adaptado para AMS830675 con SSD secundario montado en /sdb
# Mantiene mínimo 150GB libres en el disco de caché
# ============================================================

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

SERVER_NAME="JELLYFIN"
JELLYFIN_SERVICE="jellyfin"

CACHE_ROOT="/sdb/rclone-cache"
MIN_FREE_GB=150

MOUNT_LIST="/root/jelly_mounts.tsv"
WATCHDOG_SCRIPT="/root/watchdog_jelly.sh"
SYSTEMD_SERVICE="/etc/systemd/system/jelly-rclone-mounts.service"
WATCHDOG_LOG="/var/log/watchdog_jelly.log"
STATUS_FILE="/root/.jelly_status"
RESTORE_LOCK="/tmp/jellyfin_restore.lock"

JELLY_ETC="/etc/jellyfin"
JELLY_VAR="/var/lib/jellyfin"
JELLY_DB="/var/lib/jellyfin/data/jellyfin.db"

JELLY_PORT="8096"

DEPENDENCIAS=0
RCLONE=0
CONFIG=0
ESTRUCTURA=0
MOUNTS=0
JELLY_OK=0
SYSTEMD_OK=0
CRON_OK=0

pause() {
  read -r -p "Pulsa ENTER para continuar..."
}

load_status() {
  [ -f "$STATUS_FILE" ] && source "$STATUS_FILE"
}

save_status() {
  cat > "$STATUS_FILE" << EOF
DEPENDENCIAS=${DEPENDENCIAS:-0}
RCLONE=${RCLONE:-0}
CONFIG=${CONFIG:-0}
ESTRUCTURA=${ESTRUCTURA:-0}
MOUNTS=${MOUNTS:-0}
JELLY_OK=${JELLY_OK:-0}
SYSTEMD_OK=${SYSTEMD_OK:-0}
CRON_OK=${CRON_OK:-0}
EOF
}

checkmark() {
  [ "${1:-0}" = "1" ] && echo -e "${GREEN}[✔]${NC}" || echo -e "${RED}[✘]${NC}"
}

free_gb() {
  local path="$1"
  mkdir -p "$path"
  df -BG "$path" | awk 'NR==2 {gsub("G","",$4); print $4}'
}

check_min_free() {
  local path="$1"
  local free
  free=$(free_gb "$path")
  if [ "$free" -lt "$MIN_FREE_GB" ]; then
    echo -e "${RED}ERROR:${NC} solo quedan ${free}GB libres en $path. Mínimo requerido: ${MIN_FREE_GB}GB"
    return 1
  fi
  echo -e "${GREEN}OK:${NC} $path tiene ${free}GB libres"
  return 0
}

check_cache_disk() {
  if ! mountpoint -q /sdb; then
    echo -e "${RED}ERROR:${NC} /sdb no está montado. Se cancela para no escribir la caché en el disco del sistema."
    return 1
  fi
  check_min_free "$CACHE_ROOT"
}

refresh_status_from_system() {
  RCLONE=0
  CONFIG=0
  ESTRUCTURA=0
  MOUNTS=0
  JELLY_OK=0
  SYSTEMD_OK=0
  CRON_OK=0

  command -v rclone >/dev/null 2>&1 && RCLONE=1
  [ -f /root/.config/rclone/rclone.conf ] && [ -s /root/.config/rclone/rclone.conf ] && CONFIG=1
  [ -f "$MOUNT_LIST" ] && ESTRUCTURA=1

  if [ -s "$MOUNT_LIST" ]; then
    expected=0
    mounted=0
    while IFS='|' read -r remote subpath mountpoint cache_dir log_file cache_size; do
      [ -z "$remote" ] && continue
      expected=$((expected + 1))
      findmnt "$mountpoint" >/dev/null 2>&1 && mounted=$((mounted + 1))
    done < "$MOUNT_LIST"
    [ "$expected" -gt 0 ] && [ "$mounted" -eq "$expected" ] && MOUNTS=1
  fi

  if systemctl is-active --quiet "$JELLYFIN_SERVICE"; then
    JELLY_OK=1
  fi

  if systemctl is-enabled jelly-rclone-mounts.service >/dev/null 2>&1; then
    SYSTEMD_OK=1
  fi

  CURRENT_CRON="$(crontab -l 2>/dev/null)"
  if echo "$CURRENT_CRON" | grep -Fq "$WATCHDOG_SCRIPT"; then
    CRON_OK=1
  fi

  save_status
}

get_ip() {
  hostname -I 2>/dev/null | awk '{print $1}'
}

show_jelly_link() {
  IP=$(get_ip)
  echo ""
  if [ -n "$IP" ]; then
    echo -e "${GREEN}Enlace Jellyfin:${NC} http://$IP:$JELLY_PORT/web/"
  else
    echo -e "${YELLOW}No pude detectar IP. Entra con:${NC} http://IP_DEL_SERVER:$JELLY_PORT/web/"
  fi
}

show_jelly_state() {
  echo ""
  if systemctl is-active --quiet "$JELLYFIN_SERVICE"; then
    echo -e "${GREEN}${JELLYFIN_SERVICE} está ACTIVO${NC}"
  else
    echo -e "${RED}${JELLYFIN_SERVICE} está PARADO${NC}"
  fi
}

