  [ -f "$MOUNT_LIST" ] && cp -a "$MOUNT_LIST" "$DEST/"
  [ -f /root/.config/rclone/rclone.conf ] && cp -a /root/.config/rclone/rclone.conf "$DEST/"
  [ -f /root/montar_jelly.sh ] && cp -a /root/montar_jelly.sh "$DEST/"
