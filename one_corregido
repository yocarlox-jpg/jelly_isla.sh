backup_config() {
  DEST="/root/backup_jelly_config_$(date +%F_%H-%M-%S)"
  mkdir -p "$DEST"

  [ -f /root/jelly_manager.sh ] && cp -a /root/jelly_manager.sh "$DEST/"
  [ -f "$MOUNT_LIST" ] && cp -a "$MOUNT_LIST" "$DEST/"
  [ -f /root/.config/rclone/rclone.conf ] && cp -a /root/.config/rclone/rclone.conf "$DEST/"
  [ -f /root/montar_jelly.sh ] && cp -a /root/montar_jelly.sh "$DEST/"
  [ -f "$WATCHDOG_SCRIPT" ] && cp -a "$WATCHDOG_SCRIPT" "$DEST/"

  crontab -l 2>/dev/null > "$DEST/crontab.txt" || true
  systemctl cat jelly-rclone-mounts.service > "$DEST/jelly-rclone-mounts.service.txt" 2>/dev/null || true

  echo -e "${GREEN}Backup guardado en:${NC} $DEST"
}

