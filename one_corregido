  if [ -f "$MOUNT_LIST" ]; then
    return 0
  fi

  check_cache_disk || return 1
  mkdir -p "$CACHE_ROOT"

  # Cache alojada en el segundo SSD de 466GB.
  # Total teórico máximo: 205GB, dejando al menos 150GB libres.
  cat > "$MOUNT_LIST" << EOF
DROPBOX||/mnt/DROPBOX|$CACHE_ROOT/rclone_DROPBOX|/var/log/rclone-DROPBOX.log|5G
00.PEL4K|@3 ! CONTENIDO/00 PEL 4K|/mnt/00.PEL4K|$CACHE_ROOT/rclone_00.PEL4K|/var/log/rclone-00.PEL4K.log|25G
00.SER4K|@3 ! CONTENIDO/00 SER 4K|/mnt/00.SER4K|$CACHE_ROOT/rclone_00.SER4K|/var/log/rclone-00.SER4K.log|25G
01.PEL|@3 ! CONTENIDO/01 PEL|/mnt/01.PEL|$CACHE_ROOT/rclone_01.PEL|/var/log/rclone-01.PEL.log|25G
02.SER|@3 ! CONTENIDO/02 SER|/mnt/02.SER|$CACHE_ROOT/rclone_02.SER|/var/log/rclone-02.SER.log|40G
03.DIB|@3 ! CONTENIDO/03 DIB|/mnt/03.DIB|$CACHE_ROOT/rclone_03.DIB|/var/log/rclone-03.DIB.log|10G
04.DIBSER|@3 ! CONTENIDO/04 DIB SER|/mnt/04.DIBSER|$CACHE_ROOT/rclone_04.DIBSER|/var/log/rclone-04.DIBSER.log|10G
05.ANI|@3 ! CONTENIDO/05 ANI|/mnt/05.ANI|$CACHE_ROOT/rclone_05.ANI|/var/log/rclone-05.ANI.log|10G
06.ANISER|@3 ! CONTENIDO/06 ANI SER|/mnt/06.ANISER|$CACHE_ROOT/rclone_06.ANISER|/var/log/rclone-06.ANISER.log|10G
07.DOC|@3 ! CONTENIDO/07 DOC|/mnt/07.DOC|$CACHE_ROOT/rclone_07.DOC|/var/log/rclone-07.DOC.log|10G
08.DOCSER|@3 ! CONTENIDO/08 DOC SER|/mnt/08.DOCSER|$CACHE_ROOT/rclone_08.DOCSER|/var/log/rclone-08.DOCSER.log|10G
09.PTV|@3 ! CONTENIDO/09 PTV|/mnt/09.PTV|$CACHE_ROOT/rclone_09.PTV|/var/log/rclone-09.PTV.log|5G
10.CON|@3 ! CONTENIDO/10 CON|/mnt/10.CON|$CACHE_ROOT/rclone_10.CON|/var/log/rclone-10.CON.log|10G
11.DEP|@3 ! CONTENIDO/11 DEP|/mnt/11.DEP|$CACHE_ROOT/rclone_11.DEP|/var/log/rclone-11.DEP.log|5G
12.AUDLIB|@3 ! CONTENIDO/12 AUD-LIB|/mnt/12.AUDLIB|$CACHE_ROOT/rclone_12.AUDLIB|/var/log/rclone-12.AUDLIB.log|5G
EOF
}

create_structure() {
  check_cache_disk || return 1
  ensure_mount_list
  mkdir -p "$CACHE_ROOT"

  while IFS='|' read -r remote subpath mountpoint cache_dir log_file cache_size; do
    mkdir -p "$mountpoint" "$cache_dir"
  done < "$MOUNT_LIST"

  ESTRUCTURA=1
  save_status
  echo -e "${GREEN}Estructura creada.${NC}"
}

install_dependencies() {
  echo -e "${GREEN}Instalando dependencias...${NC}"
  apt update
  apt install -y \
    fuse3 curl wget unzip htop nano git ca-certificates \
    lsb-release apt-transport-https gnupg python3 tar sqlite3 pv jq lsof

  DEPENDENCIAS=1
  save_status
}

install_rclone() {
  echo -e "${GREEN}Instalando rclone...${NC}"
  if command -v rclone >/dev/null 2>&1; then
    rclone version | head -5
  else
    curl -fsSL https://rclone.org/install.sh | bash
  fi

  mkdir -p /root/.config/rclone
  touch /root/.config/rclone/rclone.conf
  chmod 600 /root/.config/rclone/rclone.conf

  grep -q '^user_allow_other' /etc/fuse.conf || echo 'user_allow_other' >> /etc/fuse.conf

  RCLONE=1
  save_status
}

edit_rclone_config() {
  mkdir -p /root/.config/rclone
  touch /root/.config/rclone/rclone.conf
  nano /root/.config/rclone/rclone.conf
  chmod 600 /root/.config/rclone/rclone.conf
  grep -q '^user_allow_other' /etc/fuse.conf || echo 'user_allow_other' >> /etc/fuse.conf
  CONFIG=1
  save_status
}

install_jellyfin() {
  echo -e "${GREEN}Instalando Jellyfin baremetal...${NC}"

  if command -v jellyfin >/dev/null 2>&1; then
    echo -e "${YELLOW}Jellyfin ya está instalado.${NC}"
    jellyfin --version || true
  else
    apt update
    apt install -y curl gnupg ca-certificates

    curl -fsSL https://repo.jellyfin.org/install-debuntu.sh | bash

    apt update
    apt install -y jellyfin
  fi

  set_jellyfin_port
  systemctl enable jellyfin
  systemctl restart jellyfin
  sleep 5

  if systemctl is-active --quiet jellyfin; then
    JELLY_OK=1
    save_status
    echo -e "${GREEN}Jellyfin instalado y activo.${NC}"
  else
    echo -e "${RED}Jellyfin no arrancó.${NC}"
  fi

  show_jelly_link
}

set_jellyfin_port() {
  NET="$JELLY_ETC/network.xml"

  mkdir -p "$JELLY_ETC"

  if [ -f "$NET" ]; then
    cp -a "$NET" "$NET.bak_port_$(date +%F_%H-%M-%S)"
    sed -i \
      -e "s|<InternalHttpPort>[0-9]*</InternalHttpPort>|<InternalHttpPort>$JELLY_PORT</InternalHttpPort>|g" \
      -e "s|<PublicHttpPort>[0-9]*</PublicHttpPort>|<PublicHttpPort>$JELLY_PORT</PublicHttpPort>|g" \
      -e "s|<HttpServerPortNumber>[0-9]*</HttpServerPortNumber>|<HttpServerPortNumber>$JELLY_PORT</HttpServerPortNumber>|g" \
      "$NET"

    grep -q "<InternalHttpPort>" "$NET" || sed -i "/<\/NetworkConfiguration>/i \  <InternalHttpPort>$JELLY_PORT</InternalHttpPort>" "$NET"
    grep -q "<PublicHttpPort>" "$NET" || sed -i "/<\/NetworkConfiguration>/i \  <PublicHttpPort>$JELLY_PORT</PublicHttpPort>" "$NET"
  fi

  chown -R jellyfin:jellyfin "$JELLY_ETC" 2>/dev/null || true
}

generate_mount_script() {
  ensure_mount_list

  cat > /root/montar_jelly.sh << 'EOF'
#!/bin/bash

CACHE_ROOT="/sdb/rclone-cache"
MOUNT_LIST="/root/jelly_mounts.tsv"
MIN_FREE_GB=150

echo "=== INICIO MONTAJE JELLY $(date) ==="

if ! mountpoint -q /sdb; then
  echo "ERROR: /sdb no está montado. No se inicia rclone para proteger el disco del sistema."
  exit 1
fi

mkdir -p "$CACHE_ROOT"

free_gb() {
  local path="$1"
  mkdir -p "$path"
  df -BG "$path" | awk 'NR==2 {gsub("G","",$4); print $4}'
}

FREE=$(free_gb "$CACHE_ROOT")
if [ "$FREE" -lt "$MIN_FREE_GB" ]; then
  echo "ERROR: solo quedan ${FREE}GB libres en $CACHE_ROOT. No monto para proteger disco."
  exit 1
fi

systemctl stop jellyfin 2>/dev/null || true
sleep 3

while IFS='|' read -r remote subpath mountpoint cache_dir log_file cache_size; do
  echo ""
  echo ">>> Montando $remote:$subpath -> $mountpoint"

  mkdir -p "$mountpoint" "$cache_dir"

  if findmnt "$mountpoint" >/dev/null 2>&1; then
    if timeout 8 find "$mountpoint" -maxdepth 1 -print -quit >/dev/null 2>&1; then
      echo "Ya estaba montado y responde: $mountpoint"
      continue
    fi

    echo "Montaje bloqueado; desmontando: $mountpoint"
    fusermount3 -uz "$mountpoint" 2>/dev/null || umount -l "$mountpoint" 2>/dev/null || true
    sleep 2
  fi

  nohup rclone mount "${remote}:${subpath}" "$mountpoint" \
    --allow-other \
    --allow-non-empty \
    --umask 002 \
    --dir-cache-time 1000h \
    --poll-interval 30s \
    --buffer-size 256M \
    --vfs-cache-mode full \
    --vfs-cache-max-size "$cache_size" \
    --vfs-cache-max-age 12h \
    --vfs-read-chunk-size 512M \
    --vfs-read-chunk-size-limit 0 \
    --cache-dir "$cache_dir" \
    --disable-http2 \
    --log-file "$log_file" \
    --log-level INFO \
    >/dev/null 2>&1 &

  sleep 2
done < "$MOUNT_LIST"

sleep 15

systemctl start jellyfin 2>/dev/null || true

echo ""
echo "=== FIN MONTAJE JELLY $(date) ==="
findmnt -t fuse.rclone || true
EOF

  chmod +x /root/montar_jelly.sh
}

generate_watchdog_script() {
  ensure_mount_list

  cat > "$WATCHDOG_SCRIPT" << EOF
#!/bin/bash

MOUNT_LIST="$MOUNT_LIST"
LOG="$WATCHDOG_LOG"
CACHE_ROOT="$CACHE_ROOT"
MIN_FREE_GB="$MIN_FREE_GB"
RESTORE_LOCK="$RESTORE_LOCK"

failed=0

echo "\$(date) - Watchdog Jelly iniciado" >> "\$LOG"

if [ -e "\$RESTORE_LOCK" ]; then
  echo "\$(date) - Restauración Jellyfin activa. Watchdog en espera." >> "\$LOG"
  exit 0
fi

if ! systemctl is-active --quiet jellyfin; then
  echo "\$(date) - Jellyfin parado. Arrancando..." >> "\$LOG"
  systemctl start jellyfin >> "\$LOG" 2>&1
fi

while IFS='|' read -r remote subpath mountpoint cache_dir log_file cache_size; do
  if ! findmnt "\$mountpoint" >/dev/null 2>&1; then
    echo "\$(date) - ERROR mount caído: \$mountpoint" >> "\$LOG"
    failed=1
    continue
  fi

  if ! timeout 8 test -d "\$mountpoint"; then
    echo "\$(date) - ERROR mount no responde: \$mountpoint" >> "\$LOG"
    fusermount3 -uz "\$mountpoint" >> "\$LOG" 2>&1 || umount -l "\$mountpoint" >> "\$LOG" 2>&1 || true
    failed=1
  fi
done < "\$MOUNT_LIST"

FREE=\$(df -BG "\$CACHE_ROOT" | awk 'NR==2 {gsub("G","",\$4); print \$4}')
if [ "\$FREE" -lt "\$MIN_FREE_GB" ]; then
  echo "\$(date) - AVISO cache con poco espacio: \${FREE}GB. Limpiando antiguos..." >> "\$LOG"
  find "\$CACHE_ROOT" -type f -mmin +240 -delete 2>/dev/null || true
fi

if [ "\$failed" -eq 1 ]; then
  echo "\$(date) - Relanzando montaje completo" >> "\$LOG"
  /root/montar_jelly.sh >> "\$LOG" 2>&1
fi
EOF

  chmod +x "$WATCHDOG_SCRIPT"
}

install_systemd_service() {
  generate_mount_script

  cat > "$SYSTEMD_SERVICE" << EOF
[Unit]
Description=Montajes rclone Jellyfin
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=/root/montar_jelly.sh
RemainAfterExit=yes
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
EOF

  systemctl daemon-reload
  systemctl enable jelly-rclone-mounts.service

  SYSTEMD_OK=1
  save_status

  echo -e "${GREEN}Systemd instalado y habilitado.${NC}"
}

install_cron_and_watchdog() {
  generate_watchdog_script

  TMP_CRON="$(mktemp)"
  crontab -l 2>/dev/null | \
    grep -v "$WATCHDOG_SCRIPT" | \
    grep -Fv "0 4 */2 * * /usr/sbin/reboot" > "$TMP_CRON" || true

  read -r -p "¿Activar también reinicio automático cada 2 días a las 04:00? [s/N]: " ACTIVAR_REBOOT

  {
    cat "$TMP_CRON"
    echo "*/5 * * * * $WATCHDOG_SCRIPT >/dev/null 2>&1"
    if [[ "$ACTIVAR_REBOOT" =~ ^[sS]$ ]]; then
      echo "0 4 */2 * * /usr/sbin/reboot"
    fi
  } | crontab -

  rm -f "$TMP_CRON"

  CRON_OK=1
  save_status

  echo -e "${GREEN}Cron instalado:${NC}"
  echo " - Watchdog Jelly cada 5 minutos"
  if [[ "$ACTIVAR_REBOOT" =~ ^[sS]$ ]]; then
    echo " - Reboot cada 2 días a las 04:00"
  else
    echo " - Reboot automático desactivado"
  fi
}

create_media_links() {
  echo -e "${GREEN}Creando enlaces compatibles /media -> /mnt...${NC}"

  mkdir -p /media

  safe_media_link() {
    local source="$1"
    local target="$2"

    if [ -L "$target" ]; then
      rm -f "$target"
    elif [ -e "$target" ]; then
      if [ -d "$target" ] && [ -z "$(find "$target" -mindepth 1 -print -quit 2>/dev/null)" ]; then
        rmdir "$target"
      else
        echo -e "${RED}No se reemplaza $target:${NC} existe y contiene datos o no es un enlace."
        return 1
      fi
    fi

    ln -s "$source" "$target"
  }

  safe_media_link /mnt/01.PEL "/media/01 PEL"
  safe_media_link /mnt/02.SER "/media/02 SER"
  safe_media_link /mnt/00.PEL4K "/media/00 PEL 4K"
  safe_media_link /mnt/00.SER4K "/media/00 SER 4K"
  safe_media_link /mnt/03.DIB "/media/03 DIB"
  safe_media_link /mnt/04.DIBSER "/media/04 DIB SER"
  safe_media_link /mnt/05.ANI "/media/05 ANI"
  safe_media_link /mnt/06.ANISER "/media/06 ANI SER"
  safe_media_link /mnt/07.DOC "/media/07 DOC"
  safe_media_link /mnt/08.DOCSER "/media/08 DOC SER"
  safe_media_link /mnt/09.PTV "/media/09 PTV"
  safe_media_link /mnt/10.CON "/media/10 CON"
  safe_media_link /mnt/11.DEP "/media/11 DEP"
  safe_media_link /mnt/12.AUDLIB "/media/12 AUDLIB"

  echo -e "${GREEN}Enlaces /media creados.${NC}"
}

create_portable_jellyfin_backup() {
  echo -e "${YELLOW}Crear backup portable de Jellyfin${NC}"
  echo ""
  echo "Incluye:"
  echo " - /etc/jellyfin"
  echo " - /var/lib/jellyfin"
  echo ""
  echo "Sirve para migrar a otro servidor o restaurar este."
  echo ""

  if [ ! -d /etc/jellyfin ] || [ ! -d /var/lib/jellyfin ]; then
    echo -e "${RED}No se encuentran las carpetas de Jellyfin.${NC}"
    return
  fi

  if ! command -v pv >/dev/null 2>&1; then
    apt update && apt install -y pv
  fi

  read -r -p "Directorio de destino [/backup]: " BACKUP_DEST
  BACKUP_DEST="${BACKUP_DEST:-/backup}"
  mkdir -p "$BACKUP_DEST"

  if [ ! -d "$BACKUP_DEST" ] || [ ! -w "$BACKUP_DEST" ]; then
    echo -e "${RED}No se puede escribir en:${NC} $BACKUP_DEST"
    return
  fi

  SOURCE_SIZE=$(du -sb /etc/jellyfin /var/lib/jellyfin 2>/dev/null |
    awk '{total += $1} END {print total + 0}')
  AVAILABLE_SIZE=$(df -PB1 "$BACKUP_DEST" | awk 'NR==2 {print $4}')
  RESERVE_SIZE=$((20 * 1024 * 1024 * 1024))

  if [ "$SOURCE_SIZE" -le 0 ]; then
    echo -e "${RED}No se pudo calcular el tamaño de Jellyfin.${NC}"
    return
  fi

  echo -e "${BLUE}Datos a respaldar:${NC} $(numfmt --to=iec-i --suffix=B "$SOURCE_SIZE")"
  echo -e "${BLUE}Espacio disponible:${NC} $(numfmt --to=iec-i --suffix=B "$AVAILABLE_SIZE")"

  if [ "$SOURCE_SIZE" -gt $((AVAILABLE_SIZE - RESERVE_SIZE)) ]; then
    echo -e "${RED}Espacio insuficiente.${NC}"
    echo "Se exige espacio para el tamaño sin comprimir y una reserva de 20GB."
    return
  fi

  TS=$(date +%F_%H-%M-%S)
  HOST_SAFE=$(hostname -s | tr -cd '[:alnum:]_.-')
  BACKUP_FILE="$BACKUP_DEST/backup_jellyfin_portable_${HOST_SAFE}_${TS}.tar.gz"
  PARTIAL_FILE="${BACKUP_FILE}.partial"
  CHECKSUM_FILE="${BACKUP_FILE}.sha256"
  WAS_ACTIVE=0
  BACKUP_OK=0

  portable_backup_cleanup() {
    if [ "$BACKUP_OK" -ne 1 ]; then
      rm -f "$PARTIAL_FILE"
    fi
    if [ "$WAS_ACTIVE" -eq 1 ] && ! systemctl is-active --quiet jellyfin; then
      systemctl start jellyfin 2>/dev/null || true
    fi
    rm -f "$RESTORE_LOCK"
  }

  trap '
    echo ""
    echo -e "${RED}Backup interrumpido. Limpiando archivo parcial...${NC}"
    portable_backup_cleanup
    trap - INT TERM
    return 130
  ' INT TERM

  touch "$RESTORE_LOCK"

  if systemctl is-active --quiet jellyfin; then
    WAS_ACTIVE=1
    echo -e "${BLUE}1/5 Deteniendo Jellyfin para congelar la base de datos...${NC}"
    systemctl stop jellyfin
  else
    echo -e "${BLUE}1/5 Jellyfin ya estaba detenido.${NC}"
  fi

  echo -e "${BLUE}2/5 Creando backup portable con progreso...${NC}"
  if ! tar -C / -cf - etc/jellyfin var/lib/jellyfin |
    pv -pterb -s "$SOURCE_SIZE" |
    gzip -1 > "$PARTIAL_FILE"; then
    echo -e "${RED}Falló la creación del backup.${NC}"
    portable_backup_cleanup
    trap - INT TERM
    return
  fi

  echo -e "${BLUE}3/5 Verificando el archivo completo...${NC}"
  COMPRESSED_SIZE=$(stat -c '%s' "$PARTIAL_FILE")
  if ! pv -pterb -s "$COMPRESSED_SIZE" "$PARTIAL_FILE" | gzip -t; then
    echo -e "${RED}La verificación falló. El archivo parcial será eliminado.${NC}"
    portable_backup_cleanup
    trap - INT TERM
    return
  fi

  echo -e "${BLUE}4/5 Guardando backup y checksum SHA-256...${NC}"
  mv "$PARTIAL_FILE" "$BACKUP_FILE"
  (
    cd "$BACKUP_DEST"
    sha256sum "$(basename "$BACKUP_FILE")"
  ) > "$CHECKSUM_FILE"
  chmod 600 "$BACKUP_FILE" "$CHECKSUM_FILE"
  BACKUP_OK=1

  echo -e "${BLUE}5/5 Restaurando el estado de Jellyfin...${NC}"
  portable_backup_cleanup
  trap - INT TERM

  echo ""
  echo -e "${GREEN}Backup portable completado.${NC}"
  echo "📦 Archivo: $BACKUP_FILE"
  echo "🔐 Checksum: $CHECKSUM_FILE"
  echo "📏 Tamaño: $(du -h "$BACKUP_FILE" | awk '{print $1}')"
  echo ""
  echo "Puedes restaurarlo con la opción 8 en este u otro servidor."
}

restore_jellyfin_backup() {
  echo -e "${YELLOW}Restaurar backup local de Jellyfin${NC}"
  echo ""

  DEFAULT_BACKUP="$(
    find /backup /root/backup /sdb -maxdepth 3 -type f \
      \( -name "*.tar.gz" -o -name "*.tgz" \) \
      -printf '%T@|%p\n' 2>/dev/null |
      sort -t '|' -k1,1nr |
      head -1 |
      cut -d '|' -f2-
  )"

  if [ -n "$DEFAULT_BACKUP" ]; then
    echo -e "${GREEN}Backup más reciente detectado:${NC}"
    echo "$DEFAULT_BACKUP"
    read -r -p "Pulsa ENTER para usarlo o escribe otra ruta: " BACKUP
    BACKUP="${BACKUP:-$DEFAULT_BACKUP}"
  else
    read -r -p "Ruta del .tar.gz de Jellyfin: " BACKUP
  fi

  if [ ! -f "$BACKUP" ]; then
    echo -e "${RED}No existe el archivo:${NC} $BACKUP"
    return
  fi

  if ! command -v pv >/dev/null 2>&1; then
    apt update && apt install -y pv
  fi

  SIZE=$(stat -c '%s' "$BACKUP")
  HUMAN_SIZE=$(du -h "$BACKUP" | awk '{print $1}')
  VALIDATION_RESULT="$(mktemp)"

  echo ""
  echo -e "${BLUE}Verificando backup de $HUMAN_SIZE...${NC}"
  echo "Esta comprobación lee el archivo completo y mostrará porcentaje, velocidad y tiempo."

  if ! pv -pterb -s "$SIZE" "$BACKUP" |
    tar -tzf - |
    awk -v result="$VALIDATION_RESULT" '
      {
        name=$0
        sub(/^\.\//, "", name)
        if (name ~ /^\// || name ~ /(^|\/)\.\.(\/|$)/) unsafe=1
        if (name == "etc/jellyfin" || index(name, "etc/jellyfin/") == 1) has_etc=1
        if (name == "var/lib/jellyfin" || index(name, "var/lib/jellyfin/") == 1) has_var=1
      }
      END {
        printf "%d %d %d\n", unsafe, has_etc, has_var > result
        if (unsafe) exit 2
      }
    '; then
    echo -e "${RED}El archivo no es válido, está dañado o contiene rutas inseguras.${NC}"
    rm -f "$VALIDATION_RESULT"
    return
  fi

  read -r HAS_UNSAFE HAS_ETC HAS_VAR < "$VALIDATION_RESULT"
  rm -f "$VALIDATION_RESULT"

  if [ "$HAS_UNSAFE" -ne 0 ]; then
    echo -e "${RED}Backup rechazado:${NC} contiene rutas absolutas o recorridos '..'."
    return
  fi

  if [ "$HAS_ETC" -ne 1 ] || [ "$HAS_VAR" -ne 1 ]; then
    echo -e "${RED}El backup no contiene etc/jellyfin y var/lib/jellyfin.${NC}"
    return
  fi

  echo ""
  echo -e "${GREEN}Verificación completada correctamente.${NC}"
  echo -e "${RED}ATENCIÓN:${NC} se restaurará sobre:"
  echo " - /etc/jellyfin"
  echo " - /var/lib/jellyfin"
  echo ""
  read -r -p "Escribe SI para continuar: " CONFIRMAR
  if [ "$CONFIRMAR" != "SI" ]; then
    echo "Cancelado."
    return
  fi

  TS=$(date +%F_%H-%M-%S)
  RAW="/root/restore_jelly_raw_$TS"
  PREVIOUS_BACKUP="/root/backups_jelly_pre_restore/jelly_antes_restore_$TS.tar.gz"
  JELLY_STOPPED=0
  RESTORE_SUCCEEDED=0

  restore_cleanup() {
    rm -rf "$RAW"
    if [ "$JELLY_STOPPED" -eq 1 ] && ! systemctl is-active --quiet jellyfin; then
      systemctl start jellyfin 2>/dev/null || true
    fi
    rm -f "$RESTORE_LOCK"
  }

  restore_previous_installation() {
    echo -e "${YELLOW}Recuperando automáticamente el estado anterior...${NC}"
    systemctl stop jellyfin 2>/dev/null || true

    rm -rf /etc/jellyfin /var/lib/jellyfin
    if tar -xzf "$PREVIOUS_BACKUP" -C /; then
      chown -R jellyfin:jellyfin /etc/jellyfin /var/lib/jellyfin 2>/dev/null || true
      chmod -R u+rwX,go+rX /etc/jellyfin /var/lib/jellyfin 2>/dev/null || true
      systemctl start jellyfin 2>/dev/null || true
      sleep 10

      if systemctl is-active --quiet jellyfin; then
        JELLY_STOPPED=0
        echo -e "${GREEN}Estado anterior recuperado y Jellyfin iniciado.${NC}"
      else
        echo -e "${RED}No se pudo iniciar tampoco el estado anterior.${NC}"
      fi
    else
      echo -e "${RED}No se pudo extraer la copia preventiva:${NC} $PREVIOUS_BACKUP"
    fi
  }

  prepare_restored_jellyfin() {
    local users_count=0
    local system_xml="/etc/jellyfin/system.xml"

    if [ -f "$JELLY_DB" ] &&
       sqlite3 "$JELLY_DB" "SELECT 1 FROM sqlite_master WHERE type='table' AND name='Users';" |
         grep -qx 1; then
      users_count=$(sqlite3 "$JELLY_DB" "SELECT COUNT(*) FROM Users;" 2>/dev/null || echo 0)
    fi

    if [ "${users_count:-0}" -gt 0 ]; then
      echo -e "${BLUE}Base restaurada con $users_count usuario(s); desactivando el asistente inicial.${NC}"

      if [ ! -f "$system_xml" ]; then
        echo -e "${RED}Falta $system_xml; no es seguro iniciar la base restaurada.${NC}"
        return 1
      fi

      if grep -q '<IsStartupWizardCompleted>false</IsStartupWizardCompleted>' "$system_xml"; then
        sed -i \
          's|<IsStartupWizardCompleted>false</IsStartupWizardCompleted>|<IsStartupWizardCompleted>true</IsStartupWizardCompleted>|' \
          "$system_xml"
      elif ! grep -q '<IsStartupWizardCompleted>true</IsStartupWizardCompleted>' "$system_xml"; then
        sed -i \
          '/<\/ServerConfiguration>/i \  <IsStartupWizardCompleted>true</IsStartupWizardCompleted>' \
          "$system_xml"
      fi
    fi

    return 0
  }

  trap '
    echo ""
    echo -e "${RED}Restauración interrumpida. Limpiando y arrancando Jellyfin...${NC}"
    restore_cleanup
    trap - INT TERM
    return 130
  ' INT TERM

  mkdir -p /root/backups_jelly_pre_restore
  mkdir -p "$RAW"
  touch "$RESTORE_LOCK"

  echo -e "${BLUE}1/10 Parando Jellyfin...${NC}"
  systemctl stop jellyfin 2>/dev/null || true
  JELLY_STOPPED=1

  echo -e "${BLUE}2/10 Creando copia preventiva con progreso...${NC}"
  CURRENT_SIZE=$(du -sb /etc/jellyfin /var/lib/jellyfin 2>/dev/null | awk '{total += $1} END {print total + 0}')
  if ! tar -C / -cf - etc/jellyfin var/lib/jellyfin |
    pv -pterb -s "$CURRENT_SIZE" |
    gzip > "$PREVIOUS_BACKUP"; then
    echo -e "${RED}No se pudo crear la copia preventiva. Se cancela sin modificar Jellyfin.${NC}"
    restore_cleanup
    trap - INT TERM
    return
  fi

  echo -e "${GREEN}Copia preventiva:${NC} $PREVIOUS_BACKUP"
  echo -e "${BLUE}3/10 Extrayendo backup con progreso...${NC}"
  if ! pv -pterb -s "$SIZE" "$BACKUP" | tar -xzf - -C "$RAW"; then
    echo -e "${RED}Falló la extracción. Jellyfin se volverá a iniciar.${NC}"
    restore_cleanup
    trap - INT TERM
    return
  fi

  if [ ! -d "$RAW/etc/jellyfin" ] || [ ! -d "$RAW/var/lib/jellyfin" ]; then
    echo -e "${RED}El backup no contiene etc/jellyfin y var/lib/jellyfin.${NC}"
    echo "Contenido detectado:"
    find "$RAW" -maxdepth 3 -type d | head -80
    restore_cleanup
    trap - INT TERM
    return
  fi

  echo -e "${BLUE}4/10 Sustituyendo carpetas verificadas...${NC}"
  rm -rf /etc/jellyfin /var/lib/jellyfin
  mv "$RAW/etc/jellyfin" /etc/jellyfin
  mv "$RAW/var/lib/jellyfin" /var/lib/jellyfin

  echo -e "${BLUE}5/10 Corrigiendo rutas Docker/antiguas a baremetal...${NC}"
  fix_jellyfin_paths

  echo -e "${BLUE}6/10 Puerto Jellyfin...${NC}"
  set_jellyfin_port

  echo -e "${BLUE}7/10 Preparando estado restaurado...${NC}"
  if ! prepare_restored_jellyfin; then
    restore_previous_installation
    restore_cleanup
    trap - INT TERM
    return
  fi

  echo -e "${BLUE}8/10 Permisos...${NC}"
  chown -R jellyfin:jellyfin /etc/jellyfin /var/lib/jellyfin
  chmod -R u+rwX,go+rX /etc/jellyfin /var/lib/jellyfin

  echo -e "${BLUE}9/10 Arrancando Jellyfin y aplicando migraciones oficiales...${NC}"
  START_TIME=$(date --iso-8601=seconds)
  systemctl start jellyfin

  echo -e "${BLUE}10/10 Comprobando servicio y API de salud...${NC}"
  for _ in $(seq 1 18); do
    if systemctl is-active --quiet jellyfin &&
       curl -fsS http://127.0.0.1:"$JELLY_PORT"/health 2>/dev/null |
         grep -q '^Healthy'; then
      RESTORE_SUCCEEDED=1
      break
    fi
    sleep 5
  done

  if [ "$RESTORE_SUCCEEDED" -eq 1 ] &&
     ! journalctl -u jellyfin --since "$START_TIME" --no-pager 2>/dev/null |
       grep -Eiq 'migration .* failed|no such column|database is malformed|\[FTL\]|fatal'; then
    JELLY_STOPPED=0
    JELLY_OK=1
    save_status
    echo -e "${GREEN}Jellyfin restaurado, migrado y saludable.${NC}"
  else
    echo -e "${RED}La restauración no superó la comprobación de salud.${NC}"
    journalctl -u jellyfin -n 80 --no-pager
    restore_previous_installation
  fi

  restore_cleanup
  trap - INT TERM

  show_jelly_link
}

fix_jellyfin_paths() {
  echo -e "${GREEN}Corrigiendo rutas Jellyfin...${NC}"

  if [ -f "$JELLY_DB" ]; then
    cp -a "$JELLY_DB" "$JELLY_DB.bak_paths_$(date +%F_%H-%M-%S)"

    sqlite3 "$JELLY_DB" "
UPDATE BaseItems SET Path = REPLACE(Path, '/config/data', '/var/lib/jellyfin') WHERE Path LIKE '/config/data%';
UPDATE BaseItems SET Path = REPLACE(Path, '/config/root', '/var/lib/jellyfin/root') WHERE Path LIKE '/config/root%';
UPDATE BaseItems SET Path = REPLACE(Path, '/config/metadata', '/var/lib/jellyfin/metadata') WHERE Path LIKE '/config/metadata%';

UPDATE BaseItems SET Path = REPLACE(Path, '/media/01 PEL', '/mnt/01.PEL') WHERE Path LIKE '/media/01 PEL%';
UPDATE BaseItems SET Path = REPLACE(Path, '/media/02 SER', '/mnt/02.SER') WHERE Path LIKE '/media/02 SER%';
UPDATE BaseItems SET Path = REPLACE(Path, '/media/00 PEL 4K', '/mnt/00.PEL4K') WHERE Path LIKE '/media/00 PEL 4K%';
UPDATE BaseItems SET Path = REPLACE(Path, '/media/00 SER 4K', '/mnt/00.SER4K') WHERE Path LIKE '/media/00 SER 4K%';
UPDATE BaseItems SET Path = REPLACE(Path, '/media/03 DIB', '/mnt/03.DIB') WHERE Path LIKE '/media/03 DIB%';
UPDATE BaseItems SET Path = REPLACE(Path, '/media/04 DIB SER', '/mnt/04.DIBSER') WHERE Path LIKE '/media/04 DIB SER%';
UPDATE BaseItems SET Path = REPLACE(Path, '/media/05 ANI', '/mnt/05.ANI') WHERE Path LIKE '/media/05 ANI%';
UPDATE BaseItems SET Path = REPLACE(Path, '/media/06 ANI SER', '/mnt/06.ANISER') WHERE Path LIKE '/media/06 ANI SER%';
UPDATE BaseItems SET Path = REPLACE(Path, '/media/07 DOC', '/mnt/07.DOC') WHERE Path LIKE '/media/07 DOC%';
UPDATE BaseItems SET Path = REPLACE(Path, '/media/08 DOC SER', '/mnt/08.DOCSER') WHERE Path LIKE '/media/08 DOC SER%';
UPDATE BaseItems SET Path = REPLACE(Path, '/media/09 PTV', '/mnt/09.PTV') WHERE Path LIKE '/media/09 PTV%';
UPDATE BaseItems SET Path = REPLACE(Path, '/media/10 CON', '/mnt/10.CON') WHERE Path LIKE '/media/10 CON%';
UPDATE BaseItems SET Path = REPLACE(Path, '/media/11 DEP', '/mnt/11.DEP') WHERE Path LIKE '/media/11 DEP%';
UPDATE BaseItems SET Path = REPLACE(Path, '/media/12 AUDLIB', '/mnt/12.AUDLIB') WHERE Path LIKE '/media/12 AUDLIB%';
"
  fi

  find /etc/jellyfin /var/lib/jellyfin -type f \( -name "*.xml" -o -name "*.json" \) -print0 2>/dev/null | xargs -0 sed -i \
    -e 's|/config/data|/var/lib/jellyfin|g' \
    -e 's|/config/root|/var/lib/jellyfin/root|g' \
    -e 's|/config/metadata|/var/lib/jellyfin/metadata|g' \
    -e 's|/config|/etc/jellyfin|g' \
    -e 's|/media/01 PEL|/mnt/01.PEL|g' \
    -e 's|/media/02 SER|/mnt/02.SER|g' \
    -e 's|/media/00 PEL 4K|/mnt/00.PEL4K|g' \
    -e 's|/media/00 SER 4K|/mnt/00.SER4K|g' || true

  chown -R jellyfin:jellyfin /etc/jellyfin /var/lib/jellyfin 2>/dev/null || true
}

review_jellyfin_libraries() {
  DB="$JELLY_DB"

  if [ ! -f "$DB" ]; then
    echo -e "${RED}No existe DB:${NC} $DB"
    return
  fi

  echo -e "${BLUE}Bibliotecas CollectionFolder:${NC}"
  sqlite3 -header -column "$DB" "
SELECT Name, Type, Path
FROM BaseItems
WHERE Type LIKE '%CollectionFolder%'
ORDER BY Name;
"

  echo ""
  echo -e "${BLUE}Conteo por rutas /mnt:${NC}"
  sqlite3 -header -column "$DB" "
SELECT
  CASE
    WHEN Path LIKE '/mnt/00.PEL4K/%' THEN '/mnt/00.PEL4K'
    WHEN Path LIKE '/mnt/00.SER4K/%' THEN '/mnt/00.SER4K'
    WHEN Path LIKE '/mnt/01.PEL/%' THEN '/mnt/01.PEL'
    WHEN Path LIKE '/mnt/02.SER/%' THEN '/mnt/02.SER'
    WHEN Path LIKE '/mnt/03.DIB/%' THEN '/mnt/03.DIB'
    WHEN Path LIKE '/mnt/04.DIBSER/%' THEN '/mnt/04.DIBSER'
    WHEN Path LIKE '/mnt/05.ANI/%' THEN '/mnt/05.ANI'
    WHEN Path LIKE '/mnt/06.ANISER/%' THEN '/mnt/06.ANISER'
    WHEN Path LIKE '/mnt/07.DOC/%' THEN '/mnt/07.DOC'
    WHEN Path LIKE '/mnt/08.DOCSER/%' THEN '/mnt/08.DOCSER'
    WHEN Path LIKE '/mnt/09.PTV/%' THEN '/mnt/09.PTV'
    WHEN Path LIKE '/mnt/10.CON/%' THEN '/mnt/10.CON'
    WHEN Path LIKE '/mnt/11.DEP/%' THEN '/mnt/11.DEP'
    WHEN Path LIKE '/mnt/12.AUDLIB/%' THEN '/mnt/12.AUDLIB'
    ELSE 'OTRAS'
  END AS Root,
  COUNT(*) AS Items
FROM BaseItems
WHERE Path IS NOT NULL
GROUP BY Root
ORDER BY Items DESC;
"
}

check_all_mounts() {
  ensure_mount_list

  echo -e "${BLUE}Comprobando montajes con timeouts seguros...${NC}"
  echo ""

  ok=0
  fail=0
  warn=0

  while IFS='|' read -r remote subpath mountpoint cache_dir log_file cache_size; do
    printf "%-25s" "$mountpoint"

    if findmnt "$mountpoint" >/dev/null 2>&1; then
      if timeout 8 find "$mountpoint" -maxdepth 1 -type d -print -quit >/dev/null 2>&1; then
        echo -e " ${GREEN}OK${NC}"
        ok=$((ok + 1))
      else
        echo -e " ${YELLOW}MONTADO PERO LENTO/BLOQUEADO${NC}"
        warn=$((warn + 1))
      fi
    else
      echo -e " ${RED}SIN MONTAR${NC}"
      fail=$((fail + 1))
    fi
  done < "$MOUNT_LIST"

  echo ""
  echo -e "${GREEN}OK:${NC} $ok"
  echo -e "${YELLOW}Lentos:${NC} $warn"
  echo -e "${RED}Fallos:${NC} $fail"
}

full_diagnostic() {
  echo -e "${BLUE}==============================================${NC}"
  echo -e "${BLUE}        DIAGNÓSTICO INTEGRAL JELLYFIN${NC}"
  echo -e "${BLUE}==============================================${NC}"
  echo ""

  echo -e "${YELLOW}1) Jellyfin${NC}"
  systemctl status jellyfin --no-pager -l | head -35
  echo ""

  echo -e "${YELLOW}2) Puerto${NC}"
  ss -lntp | grep "$JELLY_PORT" || true
  echo ""

  echo -e "${YELLOW}3) Disco/cache${NC}"
  df -h /
  df -h "$CACHE_ROOT" 2>/dev/null || true
  echo "Libre cache: $(free_gb "$CACHE_ROOT")GB"
  echo ""

  echo -e "${YELLOW}4) Montajes${NC}"
  check_all_mounts
  echo ""

  echo -e "${YELLOW}5) Errores rclone recientes${NC}"
  grep -H -Ei "too_many|error|failed|rate|429|timeout" /var/log/rclone-*.log 2>/dev/null | tail -80 || echo "Sin errores claros"
  echo ""

  echo -e "${YELLOW}6) Bibliotecas Jellyfin${NC}"
  review_jellyfin_libraries
}

